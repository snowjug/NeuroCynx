# Copy this file to .env and set your server-side key
GEMINI_API_KEY=replace_with_your_gemini_api_key
PORT=3000

# Email provider mode:
# - smtp   -> use SMTP_* values below
# - resend -> use EMAIL_API_KEY + EMAIL_FROM (single API key flow)
EMAIL_PROVIDER=smtp

# Resend API-key-only mode (free tier available)
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxxxxxxxxxxxxxxxx   # replace re_xxxxxxxxx with your real API key
# EMAIL_FROM=NeuroCynx Reports <onboarding@resend.dev>

# SMTP config for patient report email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=NeuroCynx Reports <reports@example.com>
